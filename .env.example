# Birdeye Data Services API Key (required)
# Get yours at: https://birdeye.so/developers
VITE_BIRDEYE_API_KEY=

# Helius RPC URL (required for on-chain data)
# Get yours at: https://helius.dev
VITE_HELIUS_RPC_URL=

# MapTiler API Key (required for 3D globe)
# Get yours at: https://maptiler.com
VITE_MAPTILER_API_KEY=

# Optional: OpenAI API Key (for AI market briefs)
# VITE_OPENAI_API_KEY=
